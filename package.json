{
  "name": "can-reader",
  "version": "1.0.0",
  "description": "CAN Reader — ECU binary file editor",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "app": "electron electron-main.js",
    "build:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "build:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.bluenet.canreader",
    "productName": "CAN Reader",
    "files": [
      "electron-main.js",
      "server.js",
      "db.js",
      "public/**/*",
      "node_modules/**/*",
      ".env"
    ],
    "asarUnpack": [
      "package.json",
      "server.js",
      "db.js",
      ".env",
      "public/**/*",
      "node_modules/**/*"
    ],
    "afterPack": "./afterPack.cjs",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    }
  }
}
